# Neo4j Connection
NEO4J_URI=bolt://localhost:7687
NEO4J_USER=neo4j
NEO4J_PASSWORD=

# LLM Provider: openai | anthropic | dashscope
LLM_PROVIDER=openai
LLM_API_KEY=
LLM_BASE_URL=https://api.openai.com/v1
LLM_MODEL=gpt-4o-mini
# LLM_EXTRACT_MODEL=        # Defaults to LLM_MODEL
# LLM_SMALL_MODEL=          # Defaults to LLM_MODEL
# LLM_EVOLVE_MODEL=         # Model with web search for Node Evolve (defaults to LLM_MODEL)

# Embedder Provider: openai | dashscope
EMBEDDER_PROVIDER=openai
EMBEDDER_API_KEY=
EMBEDDER_BASE_URL=https://api.openai.com/v1
EMBEDDER_MODEL=text-embedding-3-small
EMBEDDER_DIM=1536

# Optional
UI_PORT=18900
MINDREADER_CACHE=~/.mindreader/cache
# MINDGRAPH_PYTHON_PATH=  # Auto-detected from monorepo structure

# Memory Decay (optional)
# MEMORY_DECAY_ENABLED=true           # Enable/disable decay (default: true)
# MEMORY_DECAY_INTERVAL_MS=3600000    # Decay check interval (default: 1 hour)
# MEMORY_DECAY_LAMBDA=0.03            # Decay rate (default: 0.03, ~23-day half-life)
# MEMORY_DECAY_THRESHOLD=0.1          # Auto-expire below this strength (default: 0.1)
# MEMORY_DECAY_REINFORCE_DELTA=0.3    # Strength boost on access (default: 0.3)
